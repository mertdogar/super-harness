{
  "name": "@super-harness/core",
  "version": "0.0.0",
  "description": "Pure agent-orchestration engine for Super Harness: createController drives a tree of Mastra Agents with delegation edges, streaming events, and pluggable persistence — no transport, no super-line.",
  "keywords": [
    "agent",
    "agents",
    "multi-agent",
    "ai",
    "llm",
    "language-model",
    "tool-calling",
    "orchestration",
    "supervisor",
    "subagent",
    "streaming",
    "harness",
    "mastra",
    "super-line",
    "typescript"
  ],
  "homepage": "https://mertdogar.github.io/super-harness/",
  "bugs": "https://github.com/mertdogar/super-harness/issues",
  "license": "MIT",
  "author": "Mert Dogar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mertdogar/super-harness.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@super-harness/shared": "workspace:*",
    "nanoid": "^5.1.7",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@mastra/core": "^1.49.0-alpha.2"
  },
  "devDependencies": {
    "@mastra/core": "1.49.0-alpha.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
