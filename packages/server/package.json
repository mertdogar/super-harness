{
  "name": "@super-harness/server",
  "version": "0.0.0",
  "description": "Batteries-included super-line binding for Super Harness: serve() exposes a core Harness over a super-line server with durable per-node/thread Stores, the wire contract, and HITL suspension/approval broadcast.",
  "keywords": [
    "agent",
    "agents",
    "multi-agent",
    "ai",
    "llm",
    "language-model",
    "tool-calling",
    "orchestration",
    "supervisor",
    "subagent",
    "streaming",
    "harness",
    "mastra",
    "super-line",
    "typescript"
  ],
  "homepage": "https://mertdogar.github.io/super-harness/",
  "bugs": "https://github.com/mertdogar/super-harness/issues",
  "license": "MIT",
  "author": "Mert Dogar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mertdogar/super-harness.git",
    "directory": "packages/server"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@super-harness/core": "workspace:*",
    "@super-harness/shared": "workspace:*"
  },
  "peerDependencies": {
    "@mastra/core": "^1.49.0-alpha.2",
    "@super-line/collections-memory": "^0.1.0",
    "@super-line/collections-pglite": "^0.1.0",
    "@super-line/collections-sqlite": "^0.1.0",
    "@super-line/core": "^0.10.0",
    "@super-line/server": "^0.10.1",
    "@super-line/store-memory": "^0.9.0",
    "@super-line/store-pglite": "^0.2.0",
    "@super-line/store-sqlite": "^0.4.0"
  },
  "peerDependenciesMeta": {
    "@super-line/collections-pglite": { "optional": true },
    "@super-line/store-pglite": { "optional": true }
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@libsql/client": "^0.17.4",
    "@mastra/core": "1.49.0-alpha.2",
    "@super-line/client": "^0.8.0",
    "@super-line/collections-memory": "^0.1.0",
    "@super-line/collections-pglite": "^0.1.0",
    "@super-line/collections-sqlite": "^0.1.0",
    "@super-line/core": "^0.10.0",
    "@super-line/server": "^0.10.1",
    "@super-line/store-memory": "^0.9.0",
    "@super-line/store-pglite": "^0.2.0",
    "@super-line/store-sqlite": "^0.4.0",
    "@super-line/transport-websocket": "^0.6.0",
    "vitest": "^4.1.2",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=18"
  }
}
