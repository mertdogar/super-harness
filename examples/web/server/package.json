{
  "name": "@super-harness/web-server",
  "version": "0.0.0",
  "private": true,
  "description": "Fullstack web example, backend half: createHarness + serve() attached to a Hono http server.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../../.env server.ts",
    "start": "tsx --env-file=../../../.env server.ts",
    "inspect": "pnpm dlx @super-line/control-center --url ws://localhost:4111/super-line",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^4.0.3",
    "@hono/node-server": "^1.19.12",
    "@libsql/client": "^0.17.4",
    "@mastra/core": "1.49.0-alpha.2",
    "@mastra/libsql": "^1.14.3",
    "@mastra/memory": "^1.22.0",
    "@mastra/pg": "^1.14.3",
    "@super-harness/core": "workspace:*",
    "@super-harness/server": "workspace:*",
    "@super-line/adapter-libp2p": "^0.6.0",
    "@super-line/store-pglite": "^0.2.0",
    "@super-line/transport-websocket": "^0.6.0",
    "hono": "^4.12.10",
    "tsx": "^4.21.0",
    "zod": "^4.4.3",
    "ai": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "~5.8.3"
  }
}
